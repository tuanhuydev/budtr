{
  "name": "@budtr/backend",
  "root": "packages/backend",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go build -o dist/backend main.go",
        "cwd": "packages/backend"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go run main.go",
        "cwd": "packages/backend"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "air",
        "cwd": "packages/backend"
      },
      "dependsOn": ["install-air"]
    },
    "install-air": {
      "executor": "nx:run-commands",
      "options": {
        "command": "which air || go install github.com/air-verse/air@latest",
        "cwd": "packages/backend"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go test ./...",
        "cwd": "packages/backend"
      }
    },
    "tidy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go mod tidy",
        "cwd": "packages/backend"
      }
    },
    "download": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go mod download",
        "cwd": "packages/backend"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "golangci-lint run",
        "cwd": "packages/backend"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go fmt ./...",
        "cwd": "packages/backend"
      }
    }
  },
  "tags": ["type:application", "scope:backend"]
}
