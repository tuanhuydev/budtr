{
  "name": "@budtr/frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "nx serve",
    "build": "tsc -b && nx vite:build",
    "lint": "eslint .",
    "preview": "nx vite:preview",
    "deploy": "wrangler pages deploy dist",
    "deploy:staging": "wrangler pages deploy dist --env staging",
    "deploy:production": "wrangler pages deploy dist --env production",
    "wrangler:dev": "wrangler pages dev dist --local"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.3.1",
    "wrangler": "^3.0.0"
  }
}
